<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_rounded_card_16"
    android:backgroundTint="@color/white_card">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@color/separator"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pocket Options"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/text_black"
        android:layout_marginBottom="24dp"/>

    <!-- Lock/Unlock -->
    <LinearLayout
        android:id="@+id/btnMenuLock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@drawable/bg_rounded_input"
        android:backgroundTint="@color/background_off_white"
        android:layout_marginBottom="12dp"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:id="@+id/imgLockIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_lock"
            app:tint="@color/primary_blue" />
        <TextView
            android:id="@+id/tvLockLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Lock Pocket"
            android:textColor="@color/text_black"
            android:textSize="16sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Rename -->
    <LinearLayout
        android:id="@+id/btnMenuEdit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@drawable/bg_rounded_input"
        android:backgroundTint="@color/background_off_white"
        android:layout_marginBottom="12dp"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_edit"
            app:tint="@color/text_black" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Rename Pocket"
            android:textColor="@color/text_black"
            android:textSize="16sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Close -->
    <LinearLayout
        android:id="@+id/btnMenuDelete"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@drawable/bg_rounded_input"
        android:backgroundTint="#FFE5E5"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_delete"
            app:tint="@color/error_red" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Close Pocket"
            android:textColor="@color/error_red"
            android:textSize="16sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="24dp"/>

</LinearLayout>
