<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="32dp"
    android:background="@drawable/bg_sharp_button"
    android:backgroundTint="@color/white_card">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Delete Pocket"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/text_black"
        android:layout_gravity="center"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Are you sure? All funds will be returned to your main balance."
        android:textSize="17sp"
        android:textColor="@color/text_gray"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_gravity="center"
        android:layout_marginBottom="32dp"/>

    <TextView
        android:id="@+id/btnConfirmDelete"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_sharp_button"
        android:backgroundTint="@color/error_red"
        android:text="Delete"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"
        android:clickable="true"
        android:focusable="true"/>

    <TextView
        android:id="@+id/btnCancelDelete"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Cancel"
        android:gravity="center"
        android:textColor="@color/text_gray"
        android:textSize="16sp"
        android:textStyle="bold"
        android:clickable="true"
        android:focusable="true"/>

</LinearLayout>