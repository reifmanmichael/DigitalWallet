<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@color/background_off_white"
    android:paddingTop="80dp">

    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <ImageView
            android:id="@+id/imgProfileBackground"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/bg_circle_shape"
            android:padding="0dp"/>

        <ImageView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginBottom="10dp"
            android:src="@drawable/ic_profile_filled"
            app:tint="#FFFFFF"
            android:layout_gravity="center"/>
    </FrameLayout>

    <TextView
        android:id="@+id/tvProfileName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Loading..."
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/text_black"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tvProfileDetail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="..."
        android:textSize="16sp"
        android:textColor="@color/text_gray"
        android:layout_marginBottom="48dp"/>

    <TextView
        android:id="@+id/btnSignOut"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginHorizontal="24dp"
        android:background="@drawable/bg_sharp_button"
        android:backgroundTint="@color/white_card"
        android:text="Sign Out"
        android:gravity="center"
        android:textColor="#FF3B30"
        android:textSize="18sp"
        android:textStyle="bold"
        android:elevation="2dp"
        android:clickable="true"
        android:focusable="true"/>

</LinearLayout>