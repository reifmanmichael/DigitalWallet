<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_off_white">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="40dp">

            <!-- Pocket Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="80dp"
                android:paddingBottom="32dp">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="120dp"
                    android:layout_height="150dp"
                    app:cardCornerRadius="24dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="@color/white_card"
                    android:layout_marginBottom="20dp">
                    <ImageView
                        android:id="@+id/imgPocketDetailIcon"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="20dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/ic_all_purpose_illustration"/>
                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:id="@+id/tvPocketDetailName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pocket Name"
                    android:textColor="@color/text_black"
                    android:textSize="28sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvPocketDetailBalance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="₪0.00"
                    android:textColor="@color/text_black"
                    android:textSize="24sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:paddingBottom="40dp">

                <LinearLayout
                    android:id="@+id/btnWithdraw"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginEnd="20dp">
                    <ImageButton
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_circle_shape"
                        android:backgroundTint="@color/primary_blue"
                        android:src="@drawable/ic_arrow_send"
                        android:padding="18dp"
                        android:rotation="180"
                        android:scaleType="fitCenter"
                        android:clickable="false"
                        android:focusable="false"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Withdraw"
                        android:textColor="@color/text_black"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnDeposit"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginEnd="20dp">
                    <ImageButton
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_circle_shape"
                        android:backgroundTint="@color/action_deposit"
                        android:src="@drawable/ic_plus_deposit"
                        android:padding="18dp"
                        android:scaleType="fitCenter"
                        android:clickable="false"
                        android:focusable="false"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Deposit"
                        android:textColor="@color/text_black"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnMore"
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">
                    <ImageButton
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_circle_shape"
                        android:backgroundTint="#E5E5EA"
                        android:src="@drawable/ic_more"
                        android:padding="18dp"
                        android:scaleType="fitCenter"
                        android:clickable="false"
                        android:focusable="false"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="More"
                        android:textColor="@color/text_black"
                        android:textSize="14sp"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Pocket Activity Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0.5dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white_card">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Pocket Activity"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_black"
                        android:padding="20dp"/>
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/separator"/>
                    
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerPocketActivity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:visibility="gone"/>

                    <TextView
                        android:id="@+id/tvNoActivity"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="No recent transactions"
                        android:textColor="@color/text_gray"
                        android:gravity="center"
                        android:padding="40dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Header area with back button -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="30dp"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">
        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/text_black" />
    </LinearLayout>

</FrameLayout>