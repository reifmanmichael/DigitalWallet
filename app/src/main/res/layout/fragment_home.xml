<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_off_white">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/homeScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="100dp"
            android:clipToPadding="false">

            <LinearLayout
                android:id="@+id/balanceContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="60dp"
                android:paddingBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your balance"
                    android:textColor="@color/text_gray"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom">

                    <TextView
                        android:id="@+id/tvCurrencySymbol"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="₪"
                        android:textColor="@color/text_black"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"
                        android:layout_marginEnd="4dp"/>

                    <TextView
                        android:id="@+id/tvMainBalance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Loading..."
                        android:textColor="@color/text_black"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:letterSpacing="-0.02"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top|center_horizontal"
                android:paddingBottom="40dp">

                <LinearLayout
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginEnd="24dp">

                    <ImageButton
                        android:id="@+id/btnSend"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_circle_shape"
                        android:backgroundTint="@color/btn_send"
                        android:src="@drawable/ic_arrow_send"
                        android:padding="18dp"
                        android:scaleType="fitCenter"
                        android:elevation="0dp"
                        android:stateListAnimator="@null"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Send"
                        android:textColor="@color/text_black"
                        android:textSize="14sp"
                        android:layout_marginTop="12dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:layout_marginEnd="24dp">

                    <ImageButton
                        android:id="@+id/btnRequest"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_circle_shape"
                        android:backgroundTint="@color/btn_request"
                        android:src="@drawable/ic_arrow_request"
                        android:padding="18dp"
                        android:scaleType="fitCenter"
                        android:elevation="0dp"
                        android:stateListAnimator="@null"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Request"
                        android:textColor="@color/text_black"
                        android:textSize="14sp"
                        android:layout_marginTop="12dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="80dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal">

                    <ImageButton
                        android:id="@+id/btnDeposit"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/bg_circle_shape"
                        android:backgroundTint="@color/btn_deposit"
                        android:src="@drawable/ic_plus_deposit"
                        android:padding="18dp"
                        android:scaleType="fitCenter"
                        android:elevation="0dp"
                        android:stateListAnimator="@null"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Deposit\nFunds"
                        android:textColor="@color/text_black"
                        android:textSize="14sp"
                        android:gravity="center"
                        android:layout_marginTop="12dp"/>
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0.5dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Recent activity"
                            android:textSize="18sp"
                            android:textColor="@color/text_black"/>

                        <TextView
                            android:id="@+id/btnSeeAllHistory"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="See all"
                            android:textSize="14sp"
                            android:textColor="@color/text_black"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/separator"/>

                    <LinearLayout
                        android:id="@+id/recentActivityContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No recent transactions"
                            android:textColor="@color/text_gray"
                            android:gravity="center"
                            android:padding="32dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0.5dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="@color/white_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Most active"
                        android:textSize="18sp"
                        android:textColor="@color/text_black"
                        android:padding="20dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/separator"/>

                    <LinearLayout
                        android:id="@+id/mostActiveContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="No contacts yet"
                            android:textColor="@color/text_gray"
                            android:gravity="center"
                            android:padding="32dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/stickyHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/background_off_white"
        android:paddingTop="40dp"
        android:paddingBottom="12dp"
        android:elevation="4dp"
        android:alpha="0"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your balance"
            android:textColor="@color/text_gray"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/tvStickyBalance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="₪ 0.00"
            android:textColor="@color/text_black"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </LinearLayout>

</FrameLayout>